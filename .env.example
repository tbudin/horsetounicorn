# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Resend Audience ID — https://resend.com/audiences
# Create one called "Horse to Unicorn" and paste the ID here
RESEND_AUDIENCE_ID=

# Verified sender domain on Resend
EMAIL_FROM=
EMAIL_REPLY_TO=

# Prefilled address for the publish page's "Test send" (real-inbox preview).
# Falls back to EMAIL_REPLY_TO when unset.
BROADCAST_TEST_EMAIL=

# Public site URL — used in emails, OG tags, RSS feed
NEXT_PUBLIC_SITE_URL=

# Stripe Payment Link for the "buy me a coffee" CTA at the end of articles
# and broadcasts. Stripe Dashboard → Products → create a $5 one-time product
# → "Create payment link" → paste the URL here. When unset, the CTA hides.
NEXT_PUBLIC_STRIPE_TIP_URL=

# Stripe Webhook — sends an automated thank-you email to donors. Both are
# needed; when either is missing, the webhook endpoint returns 500 and no
# email is sent.
# - STRIPE_SECRET_KEY: restricted key with `Checkout Sessions: Read` perm.
#   Stripe Dashboard → Developers → API keys → Create restricted key.
# - STRIPE_WEBHOOK_SECRET: signing secret shown when you create the webhook
#   endpoint. Stripe Dashboard → Developers → Webhooks → Add endpoint with
#   URL https://www.horsetounicorn.com/api/webhooks/stripe and event
#   `checkout.session.completed`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Shared secret protecting /api/publish (post broadcast endpoint).
# Generate with: openssl rand -hex 32
PUBLISH_SECRET=

# -- Admin panel --
# Password for /admin login. Pick something strong.
ADMIN_PASSWORD=

# JWT signing key for the admin session cookie. 32+ random bytes.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Resend audience that gets the article BEFORE the main audience for review.
# Create a second audience in Resend, add the few addresses, paste its ID.
RESEND_INNER_CIRCLE_AUDIENCE_ID=

# -- Remote admin (Cloudflare R2 + GitHub commit-on-save) --
# Set these to enable admin from anywhere. Without them, the admin falls
# back to writing the local filesystem (dev mode).
#
# All eight must be set together; if any is missing, the admin uses the
# filesystem.

# Cloudflare R2 — Dashboard → R2 → "Manage R2 API Tokens" → Create token
# with "Object Read & Write" on the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Custom domain attached to the bucket (R2 → bucket → Settings → Custom
# domains). Or use the default https://pub-<hash>.r2.dev — works but ugly.
R2_PUBLIC_BASE_URL=

# GitHub — Settings → Developer settings → Personal access tokens →
# Fine-grained tokens. Scope to this repo only with "Contents: Read &
# write" + "Metadata: Read". Vercel auto-redeploys on push.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Optional: defaults to "main".
GITHUB_BRANCH=
# Optional: commit author shown in GitHub. Defaults to "horsetounicorn admin".
GITHUB_AUTHOR_NAME=
GITHUB_AUTHOR_EMAIL=
